# 复制为 .env.local（被 .gitignore），改成你后端的 LAN IP
# Expo 只会把 EXPO_PUBLIC_ 前缀的变量打进 bundle，安全
#
# 注意：.env.local 只对 `npm run start` 的本地 dev 有效。EAS Build（TestFlight/
# production IPA）不会读这个文件，必须用 EAS env / Secrets 注入。详见
# docs/architecture/account-sync.md 末尾的 "EAS env 配置" 一节。

# 后端基址（同步 + 食物识别共用同一台 mealmate backend）
# 新名字，apiClient.ts 优先用这个
EXPO_PUBLIC_API_BASE=http://<YOUR-SERVER-LAN-IP>:8000
# 旧名字，foodDetection.ts 仍兼容（apiClient.ts 也 fallback 到这个）
EXPO_PUBLIC_DETECT_API_BASE=http://<YOUR-SERVER-LAN-IP>:8000

# Gemini 2.5 Flash Vision key — 体重秤 OCR + mascot LLM 都用同一个 key
EXPO_PUBLIC_GEMINI_KEY=<YOUR-GEMINI-KEY>
# 必须是字符串 "true" 才开启 LLM mascot，空/false → 走 mock dialogues
EXPO_PUBLIC_LLM_ENABLED=true
